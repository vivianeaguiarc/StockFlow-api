# Application
NODE_ENV=development
PORT=3333
HOST=0.0.0.0
API_PREFIX=/api/v1
TRUST_PROXY=false

# PostgreSQL (Docker Compose — local only)
POSTGRES_USER=stockflow
POSTGRES_PASSWORD=stockflow
POSTGRES_DB=stockflow_db

# Database (Prisma — required in all environments)
DATABASE_URL=postgresql://stockflow:stockflow@localhost:5432/stockflow_db?schema=public

# JWT (development — use long random values in production)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
# JWT_ACCESS_SECRET=          # Preferred in production (falls back to JWT_SECRET)
# JWT_REFRESH_SECRET=         # Required in production (pepper for refresh token hashing)
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN_DAYS=7

# Rate limiting (disabled automatically when NODE_ENV=test)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_GLOBAL_MAX=100
RATE_LIMIT_GLOBAL_WINDOW_MS=900000
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_LOGIN_WINDOW_MS=900000
RATE_LIMIT_REFRESH_MAX=10
RATE_LIMIT_REFRESH_WINDOW_MS=900000
RATE_LIMIT_REGISTER_MAX=10
RATE_LIMIT_REGISTER_WINDOW_MS=3600000

# CORS (comma-separated origins; required in production for browser clients)
# CORS_ORIGINS=https://app.stockflow.com,https://admin.stockflow.com
# CORS_ORIGIN=https://app.stockflow.com   # Alias for a single origin

# Redis cache (disabled automatically when NODE_ENV=test)
REDIS_URL=redis://localhost:6379
CACHE_TTL_SECONDS=300
CACHE_ENABLED=true

# --- Production / Render (configure in dashboard — never commit real values) ---
# NODE_ENV=production
# PORT=                         # Render injects PORT automatically — do not override
# HOST=0.0.0.0
# HUSKY=0
# TRUST_PROXY=true
# PUBLIC_URL=https://stockflow-api-l4x4.onrender.com   # Base URL (Swagger adiciona /api/v1)
# DATABASE_URL=                 # Render PostgreSQL Internal Database URL
# REDIS_URL=                    # Render Key Value or Upstash Redis URL
# JWT_ACCESS_SECRET=            # Min. 32 chars (or use JWT_SECRET)
# JWT_REFRESH_SECRET=           # Min. 32 chars — separate from access token secret
# CORS_ORIGINS=https://your-frontend.com
# RATE_LIMIT_ENABLED=true
# CACHE_ENABLED=true
