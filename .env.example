# Application
NODE_ENV=development
PORT=3333
API_PREFIX=/api/v1

# PostgreSQL (Docker Compose)
POSTGRES_USER=stockflow
POSTGRES_PASSWORD=stockflow
POSTGRES_DB=stockflow_db

# Database (Prisma)
DATABASE_URL=postgresql://stockflow:stockflow@localhost:5432/stockflow_db?schema=public

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Rate limiting (disabled automatically when NODE_ENV=test)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_GLOBAL_MAX=100
RATE_LIMIT_GLOBAL_WINDOW_MS=900000
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_LOGIN_WINDOW_MS=900000
RATE_LIMIT_REGISTER_MAX=10
RATE_LIMIT_REGISTER_WINDOW_MS=3600000
