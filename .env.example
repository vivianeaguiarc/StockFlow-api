# Application
NODE_ENV=development
PORT=3333
HOST=0.0.0.0
API_PREFIX=/api/v1

# PostgreSQL (Docker Compose — local only)
POSTGRES_USER=stockflow
POSTGRES_PASSWORD=stockflow
POSTGRES_DB=stockflow_db

# Database (Prisma — required in all environments)
DATABASE_URL=postgresql://stockflow:stockflow@localhost:5432/stockflow_db?schema=public

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN_DAYS=7

# Rate limiting (disabled automatically when NODE_ENV=test)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_GLOBAL_MAX=100
RATE_LIMIT_GLOBAL_WINDOW_MS=900000
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_LOGIN_WINDOW_MS=900000
RATE_LIMIT_REGISTER_MAX=10
RATE_LIMIT_REGISTER_WINDOW_MS=3600000

# Redis cache (disabled automatically when NODE_ENV=test)
REDIS_URL=redis://localhost:6379
CACHE_TTL_SECONDS=300
CACHE_ENABLED=true
# List TTL: 60s (users list) | Detail TTL: 300s (users/:id, auth/me) — see src/shared/cache/cache-keys.ts

# --- Production / Render (configure no painel — never commit real values) ---
# NODE_ENV=production
# PORT=3333                    # Render injects PORT automatically — do not override
# HOST=0.0.0.0
# HUSKY=0                      # Disable git hooks on Render build
# PUBLIC_URL=https://your-service.onrender.com
# DATABASE_URL=                # Render PostgreSQL Internal Database URL
# REDIS_URL=                   # Render Key Value or Upstash Redis URL
# JWT_SECRET=                  # Long random secret (min. 32 chars)
# JWT_EXPIRES_IN=7d
# REFRESH_TOKEN_EXPIRES_IN_DAYS=30
# CACHE_TTL_SECONDS=300
# CACHE_ENABLED=true
NODE_ENV=development

PORT=3333

API_PREFIX=/api/v1

# PostgreSQL Local
POSTGRES_USER=stockflow
POSTGRES_PASSWORD=stockflow
POSTGRES_DB=stockflow_db

# Prisma
DATABASE_URL="postgresql://stockflow:stockflow@localhost:5432/stockflow_db?schema=public"

# Redis Local
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN=15m

# Refresh Token
REFRESH_TOKEN_EXPIRES_IN=7d

# Cache
CACHE_TTL_SECONDS=300